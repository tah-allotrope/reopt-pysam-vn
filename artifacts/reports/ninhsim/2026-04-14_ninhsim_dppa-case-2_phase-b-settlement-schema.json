{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Ninhsim DPPA Case 2 Settlement Input Schema",
  "type": "object",
  "required": [
    "matched_quantity_rule",
    "excess_generation_treatment",
    "load_kwh_series",
    "contracted_generation_kwh_series",
    "market_reference_price_vnd_per_kwh_series",
    "evn_retail_rate_vnd_per_kwh_series",
    "strike_price_vnd_per_kwh",
    "dppa_adder_vnd_per_kwh",
    "kpp_factor"
  ],
  "properties": {
    "settlement_quantity_rule": {
      "type": "string",
      "enum": [
        "min_load_and_contracted_generation"
      ]
    },
    "matched_quantity_rule": {
      "type": "string",
      "enum": [
        "min_load_and_contracted_generation"
      ]
    },
    "excess_generation_treatment": {
      "type": "string",
      "enum": [
        "excluded_from_buyer_settlement"
      ]
    },
    "market_reference_price_type": {
      "type": "string",
      "enum": [
        "cfmp",
        "fmp",
        "proxy_cfmp_or_fmp"
      ]
    },
    "load_kwh_series": {
      "type": "array",
      "minItems": 8760,
      "maxItems": 8760,
      "items": {
        "type": "number"
      }
    },
    "contracted_generation_kwh_series": {
      "type": "array",
      "minItems": 8760,
      "maxItems": 8760,
      "items": {
        "type": "number"
      }
    },
    "market_reference_price_vnd_per_kwh_series": {
      "type": "array",
      "minItems": 8760,
      "maxItems": 8760,
      "items": {
        "type": "number"
      }
    },
    "evn_retail_rate_vnd_per_kwh_series": {
      "type": "array",
      "minItems": 8760,
      "maxItems": 8760,
      "items": {
        "type": "number"
      }
    },
    "strike_price_vnd_per_kwh": {
      "type": "number"
    },
    "dppa_adder_vnd_per_kwh": {
      "type": "number"
    },
    "kpp_factor": {
      "type": "number"
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}