{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/anomalyco/reopt-pysam/data/schemas/extracted_inputs.schema.json",
  "title": "Extracted Excel Inputs",
  "description": "Schema defining required fields for data extracted from a Vietnam project Excel model for use as REopt and PySAM inputs.",
  "type": "object",
  "required": [
    "project",
    "site",
    "loads_kw",
    "load_cleaning",
    "benchmark",
    "pv_production_factor",
    "fmp_vnd_per_mwh",
    "evn_tariff"
  ],
  "properties": {
    "project": {
      "type": "string",
      "description": "Project name identifier",
      "minLength": 1
    },
    "site": {
      "type": "object",
      "description": "Site geographic and tariff metadata",
      "required": [
        "latitude",
        "longitude",
        "customer_type",
        "region",
        "voltage_level"
      ],
      "properties": {
        "latitude": { "type": "number", "minimum": -90, "maximum": 90 },
        "longitude": { "type": "number", "minimum": -180, "maximum": 180 },
        "customer_type": {
          "type": "string",
          "enum": ["industrial", "commercial", "household"]
        },
        "region": {
          "type": "string",
          "enum": ["north", "central", "south"]
        },
        "voltage_level": { "type": "string", "minLength": 1 },
        "address": { "type": "string" },
        "description": { "type": "string" }
      },
      "additionalProperties": true
    },
    "loads_kw": {
      "type": "array",
      "description": "8760-hour site load profile in kW",
      "minItems": 8760,
      "maxItems": 8760,
      "items": { "type": "number", "minimum": 0 }
    },
    "load_cleaning": {
      "type": "object",
      "description": "Summary of load cleaning / validation steps applied",
      "required": ["missing_count", "final_count"],
      "properties": {
        "missing_count": { "type": "integer", "minimum": 0 },
        "final_count": { "type": "integer", "minimum": 1 },
        "interpolated_count": { "type": "integer", "minimum": 0 },
        "negative_replaced_count": { "type": "integer", "minimum": 0 }
      }
    },
    "benchmark": {
      "type": "object",
      "description": "Benchmark tariff and load summary metrics",
      "required": [
        "annual_load_kwh",
        "annual_load_gwh",
        "weighted_evn_price_vnd_per_kwh",
        "weighted_evn_price_usd_per_kwh",
        "exchange_rate_vnd_per_usd"
      ],
      "properties": {
        "annual_load_kwh": { "type": "number", "minimum": 0 },
        "annual_load_gwh": { "type": "number", "minimum": 0 },
        "weighted_evn_price_vnd_per_kwh": { "type": "number", "minimum": 0 },
        "weighted_evn_price_usd_per_kwh": { "type": "number", "minimum": 0 },
        "exchange_rate_vnd_per_usd": { "type": "number", "minimum": 0 },
        "wholesale_rate_vnd_per_kwh": { "type": "number", "minimum": 0 },
        "wholesale_rate_usd_per_kwh": { "type": "number", "minimum": 0 },
        "peak_demand_kw": { "type": "number", "minimum": 0 }
      },
      "additionalProperties": true
    },
    "pv_production_factor": {
      "type": "number",
      "description": "PV production factor (fraction of rated capacity per hour) or site-specific scaling factor",
      "minimum": 0,
      "maximum": 2
    },
    "fmp_vnd_per_mwh": {
      "type": "array",
      "description": "8760-hour Forward Market Price series in VND/MWh (or VND/kWh per normalization)",
      "minItems": 8760,
      "maxItems": 8760,
      "items": { "type": "number", "minimum": 0 }
    },
    "evn_tariff": {
      "type": "object",
      "description": "EVN tariff parameters for the project",
      "required": ["tou_energy_rates_usd_per_kwh"],
      "properties": {
        "tou_energy_rates_usd_per_kwh": {
          "type": "array",
          "description": "8760-hour TOU energy rates in USD/kWh",
          "minItems": 8760,
          "maxItems": 8760,
          "items": { "type": "number", "minimum": 0 }
        },
        "monthly_demand_rates_usd_per_kw": {
          "type": "array",
          "minItems": 12,
          "maxItems": 12,
          "items": { "type": "number", "minimum": 0 }
        }
      },
      "additionalProperties": true
    },
    "cfmp_vnd_per_mwh": {
      "type": "array",
      "description": "Optional 8760-hour CfMP (Congestion FMP) series",
      "minItems": 8760,
      "maxItems": 8760,
      "items": { "type": "number" }
    },
    "extraction_meta": {
      "type": "object",
      "description": "Metadata about the extraction process",
      "properties": {
        "source_file": { "type": "string" },
        "excel_sheet": { "type": "string" },
        "extraction_timestamp": { "type": "string", "format": "date-time" },
        "extraction_version": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
